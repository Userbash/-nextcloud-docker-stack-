# ============================================
# DATABASE CONFIGURATION
# ============================================
POSTGRES_DB=YOUR_DATABASE_NAME
POSTGRES_USER=YOUR_DATABASE_USER
POSTGRES_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD
POSTGRES_HOST=YOUR_DATABASE_HOST
POSTGRES_PORT=5432

# ============================================
# NEXTCLOUD ADMIN
# ============================================
NEXTCLOUD_ADMIN_USER=YOUR_ADMIN_USERNAME
NEXTCLOUD_ADMIN_PASSWORD=YOUR_SECURE_ADMIN_PASSWORD

# ============================================
# DOMAIN & SSL
# ============================================
NEXTCLOUD_DOMAIN=YOUR_NEXTCLOUD_DOMAIN
NEXTCLOUD_TRUSTED_DOMAINS=YOUR_NEXTCLOUD_DOMAIN,www.YOUR_NEXTCLOUD_DOMAIN,localhost
LETSENCRYPT_EMAIL=YOUR_LETSENCRYPT_EMAIL
OVERWRITEPROTOCOL=https

# ============================================
# PHP CONFIGURATION
# ============================================
PHP_MEMORY_LIMIT=YOUR_PHP_MEMORY_LIMIT
PHP_UPLOAD_MAX_FILESIZE=YOUR_PHP_UPLOAD_MAX_FILESIZE
PHP_POST_MAX_SIZE=YOUR_PHP_POST_MAX_SIZE
PHP_MAX_EXECUTION_TIME=YOUR_PHP_MAX_EXECUTION_TIME
PHP_MAX_INPUT_TIME=YOUR_PHP_MAX_EXECUTION_TIME
PHP_OPCACHE_ENABLE=YOUR_PHP_OPCACHE_ENABLE
PHP_OPCACHE_MEMORY_CONSUMPTION=YOUR_PHP_OPCACHE_MEMORY_CONSUMPTION
PHP_APCU_ENABLED=YOUR_PHP_APCU_ENABLED

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD

# ============================================
# CONTAINER PORTS (localhost only)
# ============================================
NEXTCLOUD_HTTP_PORT=8081
NEXTCLOUD_HTTPS_PORT=8443

# ============================================
# BACKUP/MAINTENANCE
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *